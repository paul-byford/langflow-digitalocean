# Template for all configurable values.
# Copy this file to .env and fill in your own values before running setup.sh.

# Domain name or bare server IP address.
# With a domain: Caddy obtains a trusted HTTPS certificate automatically via Let's Encrypt.
# With a bare IP: the setup script converts it to a free sslip.io subdomain
#   (e.g. 1.2.3.4 becomes 1-2-3-4.sslip.io) so you still get trusted HTTPS
#   with no DNS configuration required.
DOMAIN=langflow.example.com

# Langflow superuser
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=

# PostgreSQL
POSTGRES_USER=langflow
POSTGRES_PASSWORD=
POSTGRES_DB=langflow

# Optional: pin a specific Langflow version (default: latest)
LANGFLOW_VERSION=latest
